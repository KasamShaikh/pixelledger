# Azure Document Intelligence
AZURE_DI_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=<your-key>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Deployment names (as configured in your Azure OpenAI resource)
AOAI_DEPLOYMENT_GPT5=gpt-5
AOAI_DEPLOYMENT_GPT51=gpt-5.1
AOAI_DEPLOYMENT_GPT5_MINI=gpt-5-mini
AOAI_DEPLOYMENT_GPT54_MINI=gpt-5.4-mini
AOAI_DEPLOYMENT_GPT4O=gpt-4o
AOAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini

# Deployment used for LLM-as-judge (defaults to GPT-5)
AOAI_DEPLOYMENT_JUDGE=gpt-5

# Local auth/request/login storage backend
# local: use ./data/*.json files
# blob: use Azure Blob Storage JSON files
AUTH_STORAGE_BACKEND=local

# Bootstrap admin (created on first run if no users exist) — CHANGE THESE
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSCODE=ChangeMe123!

# Required only when AUTH_STORAGE_BACKEND=blob
AUTH_BLOB_CONNECTION_STRING=
AUTH_BLOB_ACCOUNT_URL=
AUTH_BLOB_CONTAINER=appdata
AUTH_BLOB_PREFIX=auth
